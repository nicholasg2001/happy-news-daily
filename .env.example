# Anthropic API key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Email address to send the digest TO (your inbox)
RECIPIENT_EMAIL=you@example.com

# Brevo SMTP credentials — get these from https://app.brevo.com/settings/keys/smtp
# Your Brevo account login email
BREVO_SMTP_USER=your-brevo-login@example.com
# Your Brevo SMTP key (NOT your account password)
BREVO_SMTP_KEY=xsmtp-...

# The "From" address shown in the email — must be a verified sender in Brevo
SENDER_EMAIL=noreply@yourdomain.com
SENDER_NAME=Positive News Digest

# Tier selection:
#   standard (default) — Claude Haiku + RSS feeds. ~$0.11/month.
#   premium            — Claude Sonnet + live web search. ~$0.95/month.
#                        Fresher stories, more diverse sources, better prose.
TIER=standard
